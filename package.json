{
  "name": "clipforge-ai",
  "version": "1.0.0",
  "description": "YouTube Video Downloader + Clip Creator SaaS",
  "scripts": {
    "postinstall": "npm run install:all",
    "install:all": "npm install --prefix clipperai",
    "dev": "concurrently \"npm run dev --prefix clipperai\" \"npm run dev --prefix backend\"",
    "build": "npm run build --prefix clipperai",
    "start": "concurrently \"npm start --prefix clipperai\" \"npm start --prefix backend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "ffprobe-static": "^3.1.0"
  }
}
