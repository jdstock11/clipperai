# Frontend (Vercel)
# Change to your deployed backend URL in Vercel settings
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Backend (Railway / Render / VPS)
PORT=4000

# Ensure yt-dlp and ffmpeg are in PATH or download them dynamically
YTDLP_PATH=./yt-dlp
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Optional Database (if Prisma is used)
DATABASE_URL="file:./dev.db"
