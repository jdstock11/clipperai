datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  passwordHash     String?
  role             String          @default("USER") // USER or ADMIN
  downloads        Download[]      @relation("UserDownloads")
  clips            Clip[]          @relation("UserClips")
  subscriptions    Subscription[]  @relation("UserSubscriptions")
  payments         Payment[]       @relation("UserPayments")
  exportHistory    ExportHistory[] @relation("UserExportHistory")
  adminLogs        AdminLog[]      @relation("UserAdminLogs")
  apiKeys          ApiKey[]        @relation("UserApiKeys")
  notifications    Notification[]  @relation("UserNotifications")
  loginLogs        LoginLog[]      @relation("UserLoginLogs")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  plan             String          @default("FREE")
  viralClipsUsed   Int             @default(0)
  cutExportsUsed   Int             @default(0)
  mergeExportsUsed Int             @default(0)
  totalExportsUsed Int             @default(0)
  lastLogin        DateTime?
  planExpiryDate   DateTime?
  status           String          @default("ACTIVE")

  @@index([email])
  @@map("users")
}

model Download {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserDownloads", fields: [userId], references: [id], onDelete: Cascade)
  url       String
  title     String
  format    String
  quality   String
  fileSize  Int?
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("downloads")
}

model Clip {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserClips", fields: [userId], references: [id], onDelete: Cascade)
  sourceUrl String
  startTime Float
  endTime   Float
  format    String
  quality   String
  cuts      String?  // SQLite doesn't support Json natively in all old Prisma versions, but new Prisma supports Json for SQLite. I'll use String just in case or leave it if it causes issues. Actually, Prisma 5 supports Json on SQLite. Let's keep it as String for simplicity or leave as String. Wait, let's keep it as String and parse it manually if needed, or leave it. Actually, I'll use String for Json to avoid issues. Wait, existing code might expect Json. Let's try String.
  status    String   @default("PENDING")
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("clips")
}

model Job {
  id        String   @id @default(cuid())
  type      String
  status    String   @default("PENDING")
  progress  Int      @default(0)
  data      String?  // Changed to String for SQLite compatibility
  result    String?  // Changed to String for SQLite compatibility
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jobs")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  status    String   @default("ACTIVE")
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  amount        Float
  currency      String   @default("USD")
  provider      String   // Stripe, Razorpay
  transactionId String   @unique
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("payments")
}

model ExportHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserExportHistory", fields: [userId], references: [id], onDelete: Cascade)
  fileUrl     String
  type        String   // Reel, Short, Landscape
  aspectRatio String
  platform    String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@map("export_history")
}

model AdminLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserAdminLogs", fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("admin_logs")
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserApiKeys", fields: [userId], references: [id], onDelete: Cascade)
  key       String   @unique
  name      String
  status    String   @default("ACTIVE") // ACTIVE, REVOKED
  usage     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("api_keys")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // SYSTEM, PROMO, ALERT
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserLoginLogs", fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  status    String   // SUCCESS, FAILED
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("login_logs")
}

model AnimationJob {
  id            String   @id @default(cuid())
  userId        String?
  prompt        String
  storyLine     String?
  progressSteps String?
  videoUrl      String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("animation_jobs")
}
